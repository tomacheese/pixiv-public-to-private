{
  "name": "pixiv-public-to-private",
  "version": "3.0.0",
  "description": "Changes all illustrations and novels publicly bookmarked on pixiv to private bookmarks.",
  "homepage": "https://github.com/tomacheese/pixiv-public-to-private",
  "bugs": {
    "url": "https://github.com/tomacheese/pixiv-public-to-private/issues"
  },
  "license": "MIT",
  "author": "Tomachi <tomachi@tomacheese.com>",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:tomacheese/pixiv-public-to-private.git"
  },
  "scripts": {
    "start": "tsx ./src/main.ts",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "dev": "tsx watch ./src/main.ts",
    "fix": "run-z fix:prettier fix:eslint",
    "lint:tsc": "tsc",
    "lint:prettier": "prettier --check src"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.16.17",
    "@book000/node-utils": "1.25.6",
    "@book000/pixivts": "0.62.0",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "eslint-config-standard": "17.1.0",
    "prettier": "3.9.5",
    "run-z": "2.1.0",
    "tsx": "4.23.1",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
